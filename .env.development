# Development Environment Configuration
# Copy this file to .env.local and fill in your development credentials

# ============================================================
# SUPABASE Configuration (Development)
# ============================================================
# Get these from: https://app.supabase.com/
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ACCESS_TOKEN=sbp_...
SUPABASE_ORG_ID=your-org-id

# ============================================================
# OPENAI Configuration (Development)
# ============================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ============================================================
# REDIS Configuration (Development)
# ============================================================
# For Docker: redis://redis:6379
# For local: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ============================================================
# Frontend Configuration
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================
# Server Configuration
# ============================================================
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# Logging Configuration (Development)
# ============================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
