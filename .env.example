# ──────────────────────────────────────────────────────────────────────────────
# ThinkSync — Environment Variables
# Copy this file to .env (backend) and frontend/.env.local (frontend) and fill
# in the real values.  Never commit files that contain real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (Backend — service role key bypasses Row Level Security) ─────────
SUPABASE_URL=https://your-project.supabase.co
# Service role key — keep this SECRET, only used server-side
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Anon key — used as fallback when SUPABASE_SERVICE_KEY is not set
SUPABASE_ANON_KEY=your-supabase-anon-key
# Management API credentials (used by the /database endpoint to create projects)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_ORG_ID=your-supabase-org-id

# ── Redis / Upstash Redis ─────────────────────────────────────────────────────
# For local Redis:
#   REDIS_URL=redis://localhost:6379
# For Upstash Redis (recommended for production — TLS required):
#   REDIS_URL=rediss://default:<TOKEN>@<HOST>.upstash.io:6380
REDIS_URL=redis://localhost:6379

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
# gpt-4o-mini is the default: fast and cost-efficient for agent operations.
# Set to gpt-4o for higher-quality (but slower and more expensive) responses.
OPENAI_MODEL=gpt-4o-mini

# ── Frontend (Next.js — NEXT_PUBLIC_* values are embedded at build time) ──────
# Public Supabase credentials for the browser Supabase client (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Backend API base URL — set to production URL or http://localhost:8000 for dev
NEXT_PUBLIC_API_URL=https://api.thinksync.art

# ── Backend server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
