# ──────────────────────────────────────────────────────────────────────────────
# ThinkSync — Environment Variables
# Copy this file to .env (backend) and frontend/.env.local (frontend) and fill
# in the real values.  Never commit files that contain real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (Backend — service role key bypasses Row Level Security) ─────────
SUPABASE_URL=https://your-project.supabase.co
# Service role key — keep this SECRET, only used server-side
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Anon key — used as fallback when SUPABASE_SERVICE_KEY is not set
SUPABASE_ANON_KEY=your-supabase-anon-key
# Management API credentials (used by the /database endpoint to create projects)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
SUPABASE_ORG_ID=your-supabase-org-id

# ── Database — Direct PostgreSQL connection (Supabase) ────────────────────────
# Used for database migrations, direct SQL access, and ORM connections.
# Find in: Supabase Dashboard → Project Settings → Database → Connection String
# Format: postgresql://postgres:[DB-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres
# Transaction-mode pooler URL (for serverless / short-lived connections, port 6543):
# DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Redis / Upstash Redis ─────────────────────────────────────────────────────
# For local Redis:
#   REDIS_URL=redis://localhost:6379
# For Upstash Redis (recommended for production — TLS required):
#   REDIS_URL=rediss://default:<TOKEN>@<HOST>.upstash.io:6380
REDIS_URL=redis://localhost:6379
# Optional password for Redis (leave empty if no password is set)
REDIS_PASSWORD=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
# gpt-4o-mini is the default: fast and cost-efficient for agent operations.
# Set to gpt-4o for higher-quality (but slower and more expensive) responses.
OPENAI_MODEL=gpt-4o-mini

# ── Frontend (Next.js — NEXT_PUBLIC_* values are embedded at build time) ──────
# Public Supabase credentials for the browser Supabase client (anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Backend API base URL — set to production URL or http://localhost:8000 for dev
NEXT_PUBLIC_API_URL=https://api.thinksync.art

# ── Backend server ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# ── Server tunables (all have sane defaults — only override when needed) ──────
# Number of uvicorn worker processes (default: 2×CPU+1, capped at 8)
WEB_CONCURRENCY=4
# Uvicorn bind settings
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
# Seconds before an idle keep-alive connection is closed (default: 30)
UVICORN_TIMEOUT_KEEP_ALIVE=30
# Enable/disable uvicorn access log (default: true)
UVICORN_ACCESS_LOG=true
# Log verbosity: debug | info | warning | error (default: info)
UVICORN_LOG_LEVEL=info
# Per-request wall-clock timeout in seconds; SSE streams are exempt (default: 60)
REQUEST_TIMEOUT=60
# Max requests per IP per 60-second window (default: 120)
RATE_LIMIT_PER_MINUTE=120

# ── Concurrency limits ────────────────────────────────────────────────────────
# Max parallel OpenAI API calls — stay within your tier's rate limits (default: 20)
OPENAI_CONCURRENCY=20
# Max parallel outbound SSH connections (default: 50)
SSH_CONCURRENCY=50
# Max parallel Supabase / direct DB calls in the thread pool (default: 30)
DB_CONCURRENCY=30
# Redis connection pool size (default: 50)
REDIS_MAX_CONNECTIONS=50
