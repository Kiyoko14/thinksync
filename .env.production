# Production Environment Configuration
# Copy this file to your production server and fill in actual values
# NEVER commit this file to Git - use secure secret management

# ============================================================
# SUPABASE Configuration (Production)
# ============================================================
# Production Supabase project details
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-from-supabase
SUPABASE_ACCESS_TOKEN=sbp_... (for creating new projects)
SUPABASE_ORG_ID=your-organization-id

# ============================================================
# OPENAI Configuration (Production)
# ============================================================
# Production OpenAI API key - keep secure
OPENAI_API_KEY=sk-... (never log this)

# ============================================================
# REDIS Configuration (Production)
# ============================================================
# Production Redis with authentication
# Format: redis://[username:password@]host:port
# Example: redis://:password@redis.production.internal:6379
REDIS_URL=redis://:your-secure-password@redis-production.example.com:6379

# ============================================================
# Frontend Configuration (Production)
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ============================================================
# Server Configuration (Production)
# ============================================================
ENVIRONMENT=production
API_HOST=0.0.0.0
API_PORT=8000

# ============================================================
# Security Configuration (Production)
# ============================================================
# Set to false in production to hide error details
DEBUG=false

# ============================================================
# Logging Configuration (Production)
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# CORS Configuration (Production)
# ============================================================
# Update in main.py - CORS_ORIGINS should match these domains
ALLOWED_ORIGIN_1=https://yourdomain.com
ALLOWED_ORIGIN_2=https://api.yourdomain.com

# ============================================================
# Database Configuration (Production)
# ============================================================
# Optional: Database backup settings
DB_BACKUP_ENABLED=true
DB_BACKUP_SCHEDULE=daily

# ============================================================
# Monitoring & Alerts (Production)
# ============================================================
# Optional: Monitoring service integrations
SENTRY_DSN=https://... (optional error tracking)
DATADOG_API_KEY=... (optional monitoring)

# ============================================================
# SSL/TLS Configuration (Production)
# ============================================================
# Handled by reverse proxy, paths may vary
SSL_CERT_PATH=/etc/ssl/certs/yourdomain.crt
SSL_KEY_PATH=/etc/ssl/private/yourdomain.key

# ============================================================
# Storage Configuration (Production)
# ============================================================
# Optional: S3 or other cloud storage for uploaded files
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=...

# ============================================================
# Email Configuration (Production)
# ============================================================
# Optional: For sending notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=...
SMTP_PASSWORD=...

# ============================================================
# Security: IMPORTANT NOTES
# ============================================================
# 1. Use environment-specific secret management:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - GitHub Secrets (for CI/CD)
#    - Docker Swarm Secrets (for Docker)
#    - Kubernetes Secrets (for K8s)
#
# 2. Rotate secrets regularly
# 3. Never log sensitive values
# 4. Use HTTPS everywhere
# 5. Enable 2FA on all accounts
# 6. Restrict API key permissions to minimum needed
